# DeFiLlama Pro API key (optional - for yields/pool data)
DEFILLAMA_API_KEY=

# CoinGecko API key (optional - enables Pro API for higher rate limits)
COINGECKO_API_KEY=

# Base Chain RPC (optional - for direct on-chain reads)
BASE_RPC_URL=https://mainnet.base.org

# Ethereum RPC (optional)
ETHEREUM_RPC_URL=

# Upstash Redis (required for caching in production)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Public site URL
NEXT_PUBLIC_SITE_URL=https://moltllama.com
